{
  "name": "codetocloudmcp",
  "publisher": "ms-codetocloud",
  "displayName": "CodeToCloud-MCP",
  "description": "",
  "aiKey": "b7241aae-9f44-4080-889c-93c900eef1d0",
  "version": "1.20260423.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Azure/codeToCloud"
  },
  "bin": {
    "codetocloudmcp": "./out/mcpServers/entrypoint.js",
    "codetocloudmcptest": "./out/mcpServers/entrypointTest.js",
    "mcp-server-codetocloud": "./out/mcpServers/entrypointLocal.js"
  },
  "main": "./out/mcpServers/main.js",
  "files": [
    "out/"
  ],
  "scripts": {
    "clean": "rimraf ./out",
    "copy-deps": "pwsh -Command \"if (Test-Path './common') { Remove-Item -Recurse -Force './common' }; if (Test-Path './toolsImplementations') { Remove-Item -Recurse -Force './toolsImplementations' }; robocopy '../common' './common' /E /XD vsCode /NFL /NDL /NJH /NJS; if ($LASTEXITCODE -le 1) { $LASTEXITCODE = 0 }; Copy-Item -Recurse '../toolsImplementations' './toolsImplementations'\"",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint ./ --ext ts",
    "build": "npm run clean && npm run compile",
    "webpack": "npm run build && webpack --config webpack.config.js",
    "start": "node ./out/mcpServers/entrypoint.js",
    "test": "",
    "inspector": "npx @modelcontextprotocol/inspector node ./out/mcpServers/entrypoint.js",
    "pkg-exe": "npm run build && node scripts/prepare-pkg.js && webpack --config webpack.config.js && pkg ./dist/entrypoint.bundle.js --targets node18-win-x64 --compress GZip --public-packages '*' --output \"C2cMcpServer.exe\""
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "18.x",
    "@types/pako": "^1.0.3",
    "@types/uuid": "^10.0.0",
    "@types/winreg": "^1.2.36",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "node-loader": "^2.0.0",
    "pkg": "^5.8.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@azure/arm-appcontainers": "^2.1.0",
    "@azure/arm-appservice": "^16.0.0",
    "@azure/arm-authorization": "^9.0.0",
    "@azure/arm-cognitiveservices": "^7.6.0",
    "@azure/arm-compute": "^22.3.0",
    "@azure/arm-containerregistry": "^10.1.0",
    "@azure/arm-containerservice": "^22.1.0",
    "@azure/arm-machinelearning": "^3.0.0",
    "@azure/arm-msi": "^2.1.1-alpha.20250319.1",
    "@azure/arm-network": "^33.5.0",
    "@azure/arm-resources": "^6.0.0",
    "@azure/arm-storage": "^18.4.0",
    "@azure/identity": "^4.0.1",
    "@azure/arm-keyvault": "^4.0.0",
    "@azure/monitor-query": "^1.3.1",
    "@azure/openai": "^1.0.0-beta.11",
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@playwright/browser-chromium": "^1.54.1",
    "applicationinsights": "^2.9.7",
    "containerization-assist-mcp": "1.3.2",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.10",
